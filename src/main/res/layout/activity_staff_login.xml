<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_scrapbook"
    android:fillViewport="true"
    android:minHeight="800dp"
    tools:context=".StaffLoginActivity"
    tools:ignore="MissingConstraints"
    tools:deviceId="pixel_5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_poster"
            android:elevation="3dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackStaff"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="72dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:fontFamily="sans-serif-black"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="Back"
                    android:textAllCaps="false"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    app:backgroundTint="@color/yellow"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Staff Login"
                    android:textColor="@color/ink"
                    android:textSize="24sp" />
            </LinearLayout>

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="16dp"
                android:adjustViewBounds="true"
                android:contentDescription="Staff Icon"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/logo_uniwear_full" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="22dp"
                android:background="@drawable/bg_note"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:padding="12dp"
                android:text="Manage inventory, orders, and distributions"
                android:textColor="@color/ink"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="22dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:text="Log In as Staff"
                    android:textColor="@color/ink"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="18dp"
                    android:gravity="center"
                    android:text="Staff access only"
                    android:textColor="@color/muted"
                    android:textSize="14sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/staffIdInputLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Staff ID"
                    app:boxBackgroundColor="@color/auth_field_background"
                    app:boxStrokeColor="@color/line"
                    app:hintTextColor="@color/auth_field_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/staffIdInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:singleLine="true"
                        android:textColor="@color/auth_field_text"
                        android:textColorHint="@color/auth_field_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailStaffInputLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Staff Email"
                    app:boxBackgroundColor="@color/auth_field_background"
                    app:boxStrokeColor="@color/line"
                    app:hintTextColor="@color/auth_field_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailStaffInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:singleLine="true"
                        android:textColor="@color/auth_field_text"
                        android:textColorHint="@color/auth_field_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/passwordStaffInputLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Password"
                    app:boxBackgroundColor="@color/auth_field_background"
                    app:boxStrokeColor="@color/line"
                    app:endIconMode="password_toggle"
                    app:hintTextColor="@color/auth_field_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passwordStaffInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:singleLine="true"
                        android:textColor="@color/auth_field_text"
                        android:textColorHint="@color/auth_field_hint" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStaffLoginSubmit"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="22dp"
                    android:fontFamily="sans-serif-black"
                    android:text="Log In"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/maroon"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginTop="22dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/divider_line" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Need help? "
                        android:textColor="@color/muted"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvStaffSupport"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Support"
                        android:textColor="@color/maroon"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
