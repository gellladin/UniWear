<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_scrapbook"
    android:fillViewport="true"
    tools:context=".DashboardActivity"
    tools:ignore="MissingConstraints">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_poster"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_title_tab"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:letterSpacing="0"
                android:text="UniWear Dashboard"
                android:textColor="@color/ink"
                android:textSize="27sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_note"
                android:fontFamily="sans-serif-medium"
                android:lineSpacingExtra="2dp"
                android:padding="12dp"
                android:text="Manage campus gear orders, inventory, availability, payments, and release status in one place."
                android:textColor="@color/ink"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <include layout="@layout/card_metric_customers" />

                <include layout="@layout/card_metric_orders" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <include layout="@layout/card_metric_products" />

                <include layout="@layout/card_metric_sales" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtItemsSummary"
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feature_accent"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:text="128\nItems"
                    android:textColor="@color/ink"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/txtActiveOrdersSummary"
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feature_accent_red"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:text="3\nOrders"
                    android:textColor="@color/ink"
                    android:textSize="18sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtLowStockSummary"
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feature_panel"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:text="2\nLow Stock"
                    android:textColor="@color/ink"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/txtPaidSummary"
                    android:layout_width="0dp"
                    android:layout_height="86dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feature_panel"
                    android:fontFamily="sans-serif-black"
                    android:gravity="center"
                    android:text="18\nPaid"
                    android:textColor="@color/ink"
                    android:textSize="17sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-black"
                android:text="Quick Actions"
                android:textColor="@color/ink"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCatalog"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Catalog"
                    android:textAllCaps="false"
                    android:textColor="@color/ink"
                    app:backgroundTint="@color/yellow"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnOrders"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Orders"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/maroon"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInventory"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Inventory"
                    android:textAllCaps="false"
                    android:textColor="@color/ink"
                    app:backgroundTint="@color/yellow"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPayments"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Payments"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/maroon"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDistribution"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Distribution"
                    android:textAllCaps="false"
                    android:textColor="@color/ink"
                    app:backgroundTint="@color/yellow"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUsers"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Users"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/maroon"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnalytics"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Reports"
                    android:textAllCaps="false"
                    android:textColor="@color/ink"
                    app:backgroundTint="@color/yellow"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStatus"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="0dp"
                    android:layout_height="54dp"
                    android:layout_marginStart="10dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="Availability"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/maroon"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
