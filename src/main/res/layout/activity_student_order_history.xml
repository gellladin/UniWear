<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_scrapbook"
    android:fillViewport="true"
    android:minHeight="800dp"
    tools:context=".StudentOrderHistoryActivity"
    tools:ignore="MissingConstraints"
    tools:deviceId="pixel_5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Header Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_poster"
            android:elevation="3dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBackHistory"
                    style="@style/Widget.MaterialComponents.Button"
                    android:layout_width="72dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    android:text="Back"
                    android:textAllCaps="false"
                    android:textColor="@color/ink"
                    android:textSize="13sp"
                    app:backgroundTint="@color/yellow"
                    app:cornerRadius="14dp"
                    app:strokeColor="@color/line"
                    app:strokeWidth="2dp" />

                <TextView
                    android:id="@+id/txtHistoryTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-black"
                    android:text="My Order History"
                    android:textColor="@color/ink"
                    android:textSize="24sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtHistorySubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_note"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="View and track all your campus gear orders"
                android:textColor="@color/ink"
                android:textSize="14sp" />

            <!-- Summary Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feature_accent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/txtTotalOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/maroon"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="Total Orders"
                        android:textColor="@color/ink"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feature_accent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/txtReadyPickup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/maroon"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="Ready"
                        android:textColor="@color/ink"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_feature_accent_red"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/txtClaimedOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-black"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="@color/maroon"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:text="Claimed"
                        android:textColor="@color/ink"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Orders List -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif-black"
            android:text="Order Details"
            android:textColor="@color/ink"
            android:textSize="18sp" />

        <LinearLayout
            android:id="@+id/ordersListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_poster"
            android:elevation="3dp"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinueShopping"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:fontFamily="sans-serif-black"
                android:text="Continue Shopping"
                android:textAllCaps="false"
                android:textColor="@color/white"
                app:backgroundTint="@color/maroon"
                app:cornerRadius="14dp"
                app:strokeColor="@color/line"
                app:strokeWidth="2dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
